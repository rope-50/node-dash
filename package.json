{
  "name": "node-dash",
  "version": "2.0.0",
  "description": "A from-scratch MPEG-DASH video player: a custom Media Source Extensions client in vanilla JS, plus a small Node/Express server that serves and proxies DASH streams.",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "node server/index.js",
    "build": "vite build",
    "start": "node server/index.js --prod",
    "test": "vitest run"
  },
  "keywords": [
    "mpeg-dash",
    "dash",
    "media-source-extensions",
    "mse",
    "video",
    "streaming",
    "express",
    "vite"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^5.1.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "vite": "^6.3.6",
    "vitest": "^4.1.7"
  }
}
